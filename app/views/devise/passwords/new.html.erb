<div class="max-w-md mx-auto py-16 px-6 animate-fade-up">
  <div class="bg-white rounded-2xl shadow-sm border border-sand p-8 md:p-10">
    <h2 class="font-display text-3xl font-bold text-navy mb-2">Reset password</h2>
    <p class="font-body text-stone mb-8">We'll send you instructions by email</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-5">
        <div>
          <%= f.label :email %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Send Reset Instructions" %>
        </div>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
