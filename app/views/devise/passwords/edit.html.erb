<div class="max-w-md mx-auto py-16 px-6 animate-fade-up">
  <div class="bg-white rounded-2xl shadow-sm border border-sand p-8 md:p-10">
    <h2 class="font-display text-3xl font-bold text-navy mb-2">New password</h2>
    <p class="font-body text-stone mb-8">Choose a strong password</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-5">
        <div>
          <%= f.label :password, "New password" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-stone font-normal normal-case tracking-normal ml-1">(<%= @minimum_password_length %> characters min)</span>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Change Password" %>
        </div>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
