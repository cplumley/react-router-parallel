<header class="bg-navy text-cream">
  <nav class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <%= link_to root_path, class: "group flex items-center gap-3" do %>
      <div class="w-9 h-9 rounded-full bg-terracotta flex items-center justify-center text-white font-display font-bold text-lg leading-none">L</div>
      <span class="font-display text-xl font-semibold tracking-tight text-cream group-hover:text-terracotta-light transition-colors">Lisbon</span>
    <% end %>

    <div class="flex items-center gap-6 font-body text-sm">
      <% if user_signed_in? %>
        <span class="text-sand font-light"><%= current_user.name %></span>
        <%= link_to "Profile", edit_user_registration_path, class: "text-sand-dark hover:text-white transition-colors" %>
        <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-sand-dark hover:text-white transition-colors cursor-pointer" %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "text-sand-dark hover:text-white transition-colors" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "bg-terracotta text-white px-5 py-2 rounded-lg font-medium hover:bg-terracotta-dark transition-colors" %>
      <% end %>
    </div>
  </nav>
</header>
